{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{",  "close": "}" },
    { "open": "[",  "close": "]" },
    { "open": "(",  "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'",  "close": "'",  "notIn": ["string", "comment"] },
    { "open": "`",  "close": "`",  "notIn": ["string"] },
    { "open": "**", "close": "**" },
    { "open": "_",  "close": "_",  "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{",  "}"],
    ["[",  "]"],
    ["(",  ")"],
    ["\"", "\""],
    ["'",  "'"],
    ["`",  "`"],
    ["*",  "*"],
    ["_",  "_"],
    ["~",  "~"]
  ],
  "folding": {
    "markers": {
      "start": "^```\\{",
      "end":   "^```\\s*$"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}
